TELEGRAM_TOKEN=your-telegram-bot-token
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=cortexa
GOOGLE_API_KEY=your-google-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Dashboard API auth token (required for /api/* endpoints)
# The dashboard must send this as the X-Dashboard-Token header.
# DASHBOARD_SECRET=your-long-random-token

# Public dashboard URL (used to generate "Open in dashboard" links in Telegram)
# Example: https://cortexa-dashboard.vercel.app
# DASHBOARD_PUBLIC_URL=https://your-dashboard.vercel.app

# Access control: comma-separated Telegram chat IDs allowed to use the bot.
# Leave empty to allow all users (single-user / open mode).
# Get your chat ID by messaging @userinfobot on Telegram.
# ALLOWED_CHAT_IDS=123456789,987654321

# Owner chat ID: used by the scheduler to send reminders and daily digests.
# Set this to your own Telegram chat ID.
# OWNER_CHAT_ID=123456789

# Auto-send daily digest at this UTC time (HH:MM). Leave empty to disable.
# DAILY_DIGEST_TIME=21:00

# Optional: override default Pinecone region if needed
# PINECONE_ENVIRONMENT=us-east-1

# Optional: enable debug messages in Telegram
# DEBUG_MODE=true
